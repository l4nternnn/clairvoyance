			"com.shushuwonie.clairvoyance.Clairvoyance"
		],
		"client": [
			"com.shushuwonie.clairvoyance.client.ClairvoyanceClient"
		],
		"fabric-datagen": [
			"com.shushuwonie.clairvoyance.client.ClairvoyanceDataGenerator"
		]
	},
	"mixins": [
